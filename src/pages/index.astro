---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Specialities from '../components/Specialities.astro';
import About from '../components/About.astro';
import Menu from '../components/Menu.astro';
import Hours from '../components/Hours.astro';
import Gallery from '../components/Gallery.astro';
import Reviews from '../components/Reviews.astro';
import Location from '../components/Location.astro';
import Contact from '../components/Contact.astro';
import FinalCta from '../components/FinalCta.astro';

const props = {
	restaurantName: 'El Casino',
	location: 'Plaza Mayor, Nº5 - El Bonillo (AB)',
};

const heroProps = {
	heroTitle: 'Sabores auténticos del pueblo',
	heroSubtitle: 'Comida tradicional y ambiente familiar para disfrutar con los tuyos.',
	buttonText: 'Reservar mesa',
	buttonSecondaryText: 'Ver carta',
	location: 'Plaza Mayor, Nº5 - El Bonillo',
	schedule: 'Mar a Vie: 9:00 - 20:00',
};

const socialProps = {
	facebookUsername: 'elcasino',
	instagramUsername: 'casinoelbonillo',
	xUsername: 'el_casino',
};
---

<Layout title="El Casino · Bar y restaurante en la Plaza Mayor de El Bonillo">
	<Header slot="header" />

	<Hero
		title={heroProps.heroTitle}
		subtitle={heroProps.heroSubtitle}
		restaurantName={props.restaurantName}
		buttonText={heroProps.buttonText}
		buttonSecondaryText={heroProps.buttonSecondaryText}
		location={heroProps.location}
		schedule={heroProps.schedule}
	/>

	<Specialities />

	<About
		restaurantName={props.restaurantName}
		description="Un rincón de toda la vida en el corazón de El Bonillo. Cocina casera con el sabor de siempre, donde cada plato lleva el cariño y la tradición de nuestra tierra."
	/>

	<Gallery />

	<Menu />

	<Reviews />

	<Hours />

	<Location />

	<Contact />

	<FinalCta />

	<Footer
		slot="footer"
		restaurantName={props.restaurantName}
		location={props.location}
		facebookUsername={socialProps.facebookUsername}
		instagramUsername={socialProps.instagramUsername}
		xUsername={socialProps.xUsername}
	/>
</Layout>
