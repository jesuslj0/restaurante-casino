---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';

interface Props {
	restaurantName: string,
	location: string,
}

interface HeroProps {
	heroTitle: string,
	heroSubtitle: string,
}

interface SocialProps {
	facebookUsername: string,
	instagramUsername: string, 
	xUsername: string
}

const props = {
	restaurantName: 'El Casino',
	location: 'Plaza Mayor, N°5 - El Bonillo (AB)',
}

const heroProps = {
	heroTitle: "Sabores auténticos del pueblo",
	heroSubtitle: "Comida tradicional y ambiente familiar para disfrutar con los tuyos.",
	buttonText: "Reservar mesa"
}

const socialProps = {
	facebookUsername: "elcasino",
	instagramUsername: "casinoelbonillo",
	xUsername: "el_casino"
}

---

<Layout title={props.restaurantName}>
	<Header slot="header"/>
	<Hero slot="hero"
		title={heroProps.heroTitle}
		subtitle={heroProps.heroSubtitle}
		restaurantName={props.restaurantName}
		buttonText={heroProps.buttonText}
	/>

	<Footer slot="footer" 
		restaurantName={props.restaurantName} 
		location={props.location}
		facebookUsername={socialProps.facebookUsername}
		instagramUsername={socialProps.instagramUsername}
		xUsername={socialProps.xUsername}
	/>
</Layout>
