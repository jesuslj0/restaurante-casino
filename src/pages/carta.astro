<script>
  const bg = document.querySelector<HTMLElement>('.carta-bg');
  const drink = document.getElementById('cb-drink');
  const vinos = document.getElementById('vinos');

  if (bg && drink) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    // En móvil quitamos el zoom lento (Ken Burns): reescalar el fondo fijo a
    // pantalla completa en cada frame provoca tirones al scrollear rápido. El
    // crossfade (opacidad) sí se mantiene porque es barato (compositing GPU).
    const zoom = !reduce && !window.matchMedia('(max-width: 767px)').matches;
    let ticking = false;

    const update = () => {
      ticking = false;
      const vh = window.innerHeight;

      // Zoom lento (Ken Burns) ligado al avance total — solo en escritorio
      if (zoom) {
        const docH = document.documentElement.scrollHeight;
        const sp = Math.min(1, Math.max(0, window.scrollY / Math.max(1, docH - vh)));
        bg.style.setProperty('--cb-scale', (1 + sp * 0.07).toFixed(4));
      }

      // Crossfade comida → bebida según se acerca la sección de vinos
      if (vinos) {
        const top = vinos.getBoundingClientRect().top;
        let p = 1 - (top - vh * 0.35) / (vh * 0.6);
        p = Math.min(1, Math.max(0, p));
        drink.style.opacity = String(p);
      }
    };

    const onScroll = () => {
      if (!ticking) { ticking = true; requestAnimationFrame(update); }
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', update);
    update();
  }

  // ---------- Desplegable de categorías (móvil) ----------
  const dd = document.querySelector<HTMLElement>('.cat-dd');
  if (dd) {
    const btn = dd.querySelector<HTMLButtonElement>('.cat-dd-btn');
    const menu = dd.querySelector<HTMLElement>('.cat-dd-menu');
    const label = dd.querySelector<HTMLElement>('.cat-dd-label');
    const ico = dd.querySelector<HTMLElement>('.cat-dd-ico');

    if (btn && menu && label) {
      const open = () => { menu.hidden = false; btn.setAttribute('aria-expanded', 'true'); };
      const close = () => { menu.hidden = true; btn.setAttribute('aria-expanded', 'false'); };

      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        menu.hidden ? open() : close();
      });
      menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
      document.addEventListener('click', (e) => {
        if (!dd.contains(e.target as Node)) close();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });

      // Scroll-spy: la etiqueta del botón refleja la sección visible.
      const links = Array.from(menu.querySelectorAll<HTMLAnchorElement>('a'));
      const targets = links
        .map((a) => {
          const id = (a.getAttribute('href') || '').slice(1);
          const el = document.getElementById(id);
          const svg = a.querySelector('svg');
          return el ? { el, text: (a.textContent || '').trim(), iconHTML: svg ? svg.outerHTML : '' } : null;
        })
        .filter((t): t is { el: HTMLElement; text: string; iconHTML: string } => t !== null);

      if ('IntersectionObserver' in window && targets.length) {
        const spy = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const t = targets.find((x) => x.el === entry.target);
                if (t) {
                  label.textContent = t.text;
                  if (ico && t.iconHTML) ico.innerHTML = t.iconHTML;
                }
              }
            });
          },
          { rootMargin: '-45% 0px -50% 0px' }
        );
        targets.forEach((t) => spy.observe(t.el));
      }
    }
  }
</script>
