---

<Layout title="Carta · El Casino · Bar y restaurante en El Bonillo" description="La carta de El Casino: para picar, tapas de carne y pescado, ibéricos de Huelva, hamburguesas, bocadillería, platos combinados, postres caseros, vinos y bebidas.">
  <!-- Fondo fotográfico fijo: comida → (crossfade) → bebida + zoom lento -->
  <div class="carta-bg" aria-hidden="true">
    <div class="cb-img cb-food"></div>
    <div class="cb-img cb-drink" id="cb-drink"></div>
    <div class="cb-veil"></div>
    <div class="cb-grain"></div>
  </div>

  <!-- Hero de la carta (sobre el fondo fotográfico fijo) -->
  <section class="carta-hero">
    <a href="/" class="carta-back" aria-label="Volver al inicio">
      <Icon name="lucide:arrow-left" />
      <span class="carta-back-label">Volver</span>
    </a>
    <div class="carta-hero-inner reveal">
      <p class="eyebrow">• Bar · Restaurante · El Bonillo •</p>
      <h1 class="carta-title">Nuestra <span class="title-highlight">carta</span></h1>
    </div>
  </section>

  <!-- Navegación de categorías (sticky): desplegable en móvil, píldora en escritorio -->
  <nav class="cat-nav" aria-label="Secciones de la carta">
    <!-- Botón desplegable (móvil) -->
    <div class="cat-dd">
      <button type="button" class="cat-dd-btn" aria-expanded="false" aria-controls="cat-dd-menu">
        <span class="cat-dd-ico" aria-hidden="true"><Icon name="lucide:utensils-crossed" /></span>
        <span class="cat-dd-label">Ver secciones</span>
        <Icon name="lucide:chevron-down" class="cat-dd-caret" />
      </button>
      <ul id="cat-dd-menu" class="cat-dd-menu" hidden>
        {categories.map((c) => (
          <li><a href={`#${c.id}`}><Icon name={c.icon} />{c.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Píldora horizontal (escritorio) -->
    <ul class="cat-pill">
      {categories.map((c) => (
        <li><a href={`#${c.id}`}>{c.label}</a></li>
      ))}
    </ul>
  </nav>

  <!-- 01 · Para picar -->
  <section id="picar" class="menu-block block-dark">
    <div class="block-inner">
      <header class="block-head reveal">
        <span class="block-num">01</span>
        <div>
          <p class="eyebrow">Para compartir</p>
          <h2 class="section-title">Para picar</h2>
        </div>
      </header>
      <div class="reveal">
        <DishList items={picar} cols={2} />
      </div>
    </div>
  </section>

  <!-- 02 · Tapas de carne -->
  <section id="carne" class="menu-block block-warm">
    <div class="block-inner">
      <header class="block-head reveal">
        <span class="block-num">02</span>
        <div>
          <p class="eyebrow">A la plancha y al punto</p>
          <h2 class="section-title">Tapas de carne</h2>
        </div>
      </header>
      <div class="reveal">
        <DishList items={carne} cols={2} />
      </div>
    </div>
  </section>

  <!-- 03 · Tapas de pescado -->
  <section id="pescado" class="menu-block block-dark">
    <div class="block-inner">
      <header class="block-head reveal">
        <span class="block-num">03</span>
        <div>
          <p class="eyebrow">Del mar a la mesa</p>
          <h2 class="section-title">Tapas de pescado</h2>
        </div>
      </header>
      <div class="reveal">
        <DishList items={pescado} cols={2} />
      </div>
    </div>
  </section>

  <!-- 04 · Ibéricos de Huelva (destacado) -->
  <section id="ibericos" class="menu-block block-warm">
    <div class="block-inner">
      <header class="block-head reveal">
        <span class="block-num">04</span>
        <div>
          <p class="eyebrow">Denominación de origen</p>
          <h2 class="section-title">Ibéricos de Huelva</h2>
        </div>
      </header>
      <div class="iberico-card reveal">
        <div class="iberico-badge">
          <Icon name="lucide:award" />
          <span>Selección de bellota</span>
        </div>
        <DishList items={ibericos} />
      </div>
    </div>
  </section>

  <!-- 05 · Hamburguesas -->
  <section id="hamburguesas" class="menu-block block-dark">
    <div class="block-inner">
      <header class="block-head reveal">
        <span class="block-num">05</span>
        <div>
          <p class="eyebrow">Recién hechas</p>
          <h2 class="section-title">Hamburguesas</h2>
        </div>
      </header>
      <div class="burger-grid">
        {hamburguesas.map((b, i) => (
          <article class="burger-card reveal" style={`--reveal-delay:${i * 70}ms`}>
            <div class="burger-icon"><Icon name={b.icon} /></div>
            <div class="burger-body">
              <h3 class="burger-name">{b.name}</h3>
              <p class="burger-desc">{b.desc}</p>
            </div>
            <span class="burger-price">{b.price}</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 06 · Bocadillería: bocadillos, tostas y sándwiches -->
  <section id="bocadilleria" class="menu-block block-warm">
    <div class="block-inner">
      <header class="block-head reveal">
        <span class="block-num">06</span>
        <div>
          <p class="eyebrow">Pan de la casa</p>
          <h2 class="section-title">Bocadillería</h2>
        </div>
      </header>

      <!-- Bocadillos con tres tamaños -->
      <div class="boc-panel reveal">
        <div class="boc-panel-head">
          <h3 class="sub-title"><Icon name="lucide:sandwich" /> Bocadillos</h3>
          <p class="boc-legend">
            <span><b>E</b> Entero</span>
            <span><b>M</b> Medio</span>
            <span><b>MT</b> Montado</span>
          </p>
        </div>
        <p class="boc-note">Ingrediente extra +1,00 €</p>
        <div class="boc-table-wrap">
          <table class="boc-table">
            <thead>
              <tr>
                <th scope="col">Bocadillo</th>
                <th scope="col">Entero</th>
                <th scope="col">Medio</th>
                <th scope="col">Montado</th>
              </tr>
            </thead>
            <tbody>
              {bocadillos.map((b) => (
                <tr>
                  <th scope="row">{b.name}</th>
                  <td class="boc-entero"><span class="boc-ab">E</span>{b.e} €</td>
                  <td><span class="boc-ab">M</span>{b.m} €</td>
                  <td><span class="boc-ab">MT</span>{b.mt} €</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Tostas y sándwiches -->
      <div class="duo-grid">
        <article class="duo-card reveal">
          <h3 class="sub-title"><Icon name="lucide:croissant" /> Tostas</h3>
          <DishList items={tostas} />
        </article>
        <article class="duo-card reveal" style="--reveal-delay:90ms">
          <h3 class="sub-title"><Icon name="lucide:sandwich" /> Sándwiches</h3>
          <p class="sub-note">Ingrediente extra +1,00 €</p>
          <DishList items={sandwiches} />
        </article>
      </div>
    </div>
  </section>

  <!-- 07 · Platos combinados -->
  <section id="combinados" class="menu-block block-dark">
    <div class="block-inner">
      <header class="block-head reveal">
        <span class="block-num">07</span>
        <div>
          <p class="eyebrow">Plato completo</p>
          <h2 class="section-title">Platos combinados</h2>
        </div>
      </header>
      <p class="block-note reveal">
        <Icon name="lucide:egg-fried" /> Todos incluyen 2 huevos fritos y patatas
      </p>
      <div class="reveal">
        <DishList items={combinados} cols={2} />
      </div>
    </div>
  </section>

  <!-- 08 · Postres -->
  <section id="postres" class="menu-block block-warm">
    <div class="block-inner">
      <header class="block-head reveal">
        <span class="block-num">08</span>
        <div>
          <p class="eyebrow">El final dulce</p>
          <h2 class="section-title">Postres</h2>
        </div>
      </header>
      <div class="reveal">
        <DishList items={postres} cols={2} />
      </div>
    </div>
  </section>

  <!-- Helados ULALÁ (estacional, verano) -->
  <Ulala />

  <!-- 09 · Vinos -->
  <section id="vinos" class="menu-block block-dark">
    <div class="block-inner">
      <header class="block-head reveal">
        <span class="block-num">09</span>
        <div>
          <p class="eyebrow">Carta de vinos</p>
          <h2 class="section-title">Vinos</h2>
        </div>
      </header>
      <div class="wine-grid">
        <article class="wine-card reveal">
          <div class="wine-head wine-red">
            <span class="wine-icon"><Icon name="lucide:wine" /></span>
            <h3 class="wine-title">Tintos</h3>
          </div>
