---
// Lista de platos reutilizable con líder de puntos y precio alineado.
// Soporta descripción, variantes (media/ración, etc.) y precio "S/M".
export interface DishItem {
  name: string;
  desc?: string;
  price?: string;
  variants?: { label: string; price: string }[];
}

interface Props {
  items: DishItem[];
  cols?: 1 | 2;
}

const { items, cols = 1 } = Astro.props;
---

<ul class:list={['dish-list', { 'two-col': cols === 2 }]}>
  {items.map((dish) => (
    <li class:list={['dish', { 'no-leader': !dish.price }]}>
      <div class="dish-text">
        <span class="dish-name">{dish.name}</span>
        {dish.desc && <span class="dish-desc">{dish.desc}</span>}
        {dish.variants && (
          <span class="dish-variants">
            {dish.variants.map((v) => `${v.label} · ${v.price}`).join('   ')}
          </span>
        )}
      </div>
      {dish.price && (
        <>
          <span class="dish-dots" aria-hidden="true"></span>
          <span class:list={['dish-price', { 'is-market': dish.price === 'S/M' }]}>
            {dish.price}
          </span>
        </>
      )}
    </li>
  ))}
</ul>

<style>
  .dish-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .two-col {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.1rem 3rem;
  }
  .dish {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .dish.no-leader {
    display: block;
  }
  .dish-text {
    display: flex;
    flex-direction: column;
  }
  .dish-name {
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.35;
  }
  .dish-desc {
    color: var(--color-text-secondary);
    font-size: 0.8rem;
    font-style: italic;
    margin-top: 0.15rem;
    line-height: 1.4;
  }
  .dish-variants {
    margin-top: 0.3rem;
    color: var(--color-accent);
    font-family: var(--font-sans-semibold);
    font-size: 0.8rem;
    letter-spacing: 0.01em;
  }
  .dish-dots {
    flex: 1;
    border-bottom: 1px dotted rgba(225, 220, 201, 0.25);
    transform: translateY(-3px);
  }
  .dish-price {
    color: var(--color-accent-2);
    font-family: var(--font-sans-semibold);
    font-size: 0.95rem;
    white-space: nowrap;
  }
  .dish-price.is-market {
    color: var(--color-text-secondary);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
  }

  @media (min-width: 768px) {
    .two-col {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
