---
import { Icon } from 'astro-icon/components';

// NOTA: reseñas de ejemplo. Sustituir por las reales (Google, redes...) manteniendo
// la estructura del array `reviews`.
const reviews = [
  {
    text: 'Estuvimos comiendo el menú de fin de semana y todo estupendo, tanto es así que repetimos al día siguiente con el arroz de bogavante que estaba riquísimo. La torrija de postre me encantó y el vino de la zona, buenísimo.',
    author: 'Patricia B.',
    origin: 'Google',
    rating: 5,
  },
  {
    text: 'Menú de fin de semana, ¡no se puede pedir más! Arroz con bogavante muy bueno, emperador y secreto todo en su punto, postres caseros muy buenos, servicio muy bueno, calidad precio excelente.',
    author: 'Cruz Pilar A.',
    origin: 'Google',
    rating: 5,
  },
  {
    text: 'Bonito local con aspecto de lo que es, un Casino como los de antes. La atención y el trato son estupendos, pero lo mejor la comida: la Carne de Boda y la Oreja a la plancha son excelentes.',
    author: 'nano',
    origin: 'Google',
    rating: 5,
  },
  {
    text: 'Lugar excelente. Comida de 10. Servicio y atención estupenda. Rápidos, atentos y muy profesionales. Mis felicitaciones a todo el equipo.',
    author: 'Lola de España',
    origin: 'Google',
    rating: 5,
  },
  {
    text: 'Comida muy rica, buena atención, buen ambiente y muy limpio. Muy recomendado.',
    author: 'Ruth T.',
    origin: 'Google',
    rating: 5,
  },
  {
    text: 'La comida muy buena, el servicio impecable y el ambiente muy agradable.',
    author: 'Mariajo',
    origin: 'Google',
    rating: 5,
  },
  {
    text: 'La comida es exquisita y el lugar es muy acogedor. Volveré cuando vuelva a este precioso pueblo.',
    author: 'David I.',
    origin: 'Google',
    rating: 5,
  },
  {
    text: 'Vinimos de paso y hemos quedado encantados con todo, altamente recomendable. ¡Volveremos!',
    author: 'Matías M.',
    origin: 'Google',
    rating: 5,
  },
  {
    text: 'Muy acogedor. Éramos dos y aunque tardamos en ser atendidos, mereció la pena.',
    author: 'Jabi',
    origin: 'Google',
    rating: 4,
  },
];

const ratingAvg = '4,0';
const ratingCount = '81';

// Tres columnas con velocidades distintas. La 2ª y 3ª aparecen en pantallas grandes.
const columns = [
  { items: reviews.slice(0, 3), dur: 34, cls: '' },
  { items: reviews.slice(3, 6), dur: 42, cls: 'col-md' },
  { items: reviews.slice(6, 9), dur: 38, cls: 'col-lg' },
];
---

<section id="resenas" class="rev-section">
  <div class="rev-inner">
    <header class="rev-head reveal">
      <p class="eyebrow">• Lo que dicen •</p>
      <h2 class="section-title">La gente del pueblo lo tiene claro</h2>
      <div class="rev-score">
        <span class="rev-stars" aria-hidden="true">
          {Array.from({ length: 5 }).map(() => <Icon name="lucide:star" class="rev-star" />)}
        </span>
        <span class="rev-score-text">
          <strong>{ratingAvg}</strong> de media · {ratingCount} reseñas
        </span>
      </div>
    </header>

    <div class="rev-cols reveal" style="--reveal-delay:120ms">
      {columns.map((col) => (
        <div class:list={['rev-col', col.cls]}>
          <div class="rev-col-track" style={`--dur:${col.dur}s`}>
            {[...col.items, ...col.items].map((rev, idx) => {
              const dup = idx >= col.items.length;
              return (
                <figure class="rev-card" aria-hidden={dup ? 'true' : undefined} data-dup={dup ? '' : undefined}>
                  <span class="rev-card-stars" aria-label={`${rev.rating} de 5 estrellas`}>
                    {Array.from({ length: rev.rating }).map(() => (
                      <Icon name="lucide:star" class="rev-star" />
                    ))}
                  </span>
                  <blockquote class="rev-text">{rev.text}</blockquote>
                  <figcaption class="rev-author">
                    <span class="rev-avatar" aria-hidden="true">{rev.author.charAt(0)}</span>
                    <span class="rev-author-meta">
                      <span class="rev-name">{rev.author}</span>
                      <span class="rev-origin">{rev.origin}</span>
                    </span>
                  </figcaption>
                </figure>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .rev-section {
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-secondary) 35%, var(--color-bg) 100%);
    padding: 4rem 1.5rem;
  }

  .rev-inner {
    max-width: 72rem;
    margin: 0 auto;
  }

  .rev-head {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .rev-score {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1.25rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-accent-25);
  }

  .rev-stars {
    display: inline-flex;
    gap: 0.1rem;
  }

  .rev-star {
    width: 1rem;
    height: 1rem;
    color: var(--color-accent);
    fill: var(--color-accent);
  }

  .rev-score-text {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  .rev-score-text strong {
    color: var(--color-text);
    font-family: var(--font-sans-semibold);
  }

  /* ---------- Columnas con scroll infinito ---------- */
  .rev-cols {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    max-height: 24rem;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to bottom, transparent, #000 14%, #000 86%, transparent);
    mask-image: linear-gradient(to bottom, transparent, #000 14%, #000 86%, transparent);
  }

  .rev-col {
    width: 100%;
    max-width: 22rem;
  }

  /* La 2ª columna aparece en tablet, la 3ª en escritorio. */
  .col-md,
  .col-lg {
    display: none;
  }

  .rev-col-track {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding-bottom: 1.25rem; /* iguala al gap para que el bucle sea continuo */
    animation: rev-scroll var(--dur, 34s) linear infinite;
    will-change: transform;
  }

  /* Pausa al interactuar con la sección. */
  .rev-cols:hover .rev-col-track,
  .rev-cols:focus-within .rev-col-track {
    animation-play-state: paused;
  }

  @keyframes rev-scroll {
    from { transform: translateY(0); }
    to { transform: translateY(-50%); }
  }

  .rev-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem;
    border-radius: 1.5rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    box-shadow: 0 18px 40px -30px rgba(0, 0, 0, 0.9);
  }

  .rev-card-stars {
    display: inline-flex;
    gap: 0.15rem;
  }

  .rev-text {
    color: var(--color-text);
    font-family: var(--font-serif);
    font-size: 1.02rem;
    line-height: 1.6;
    margin: 0;
  }

  .rev-author {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .rev-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    flex-shrink: 0;
    background: var(--color-accent-25);
    color: var(--color-accent);
    font-family: var(--font-serif-semibold);
    font-size: 1.05rem;
  }

  .rev-author-meta {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .rev-name {
    color: var(--color-text);
    font-family: var(--font-sans-semibold);
    font-size: 0.95rem;
  }

  .rev-origin {
    color: var(--color-text-secondary);
    font-size: 0.8rem;
  }

  @media (min-width: 768px) {
    .rev-section {
      padding: 5.5rem 3rem;
    }
    .col-md {
      display: block;
    }
  }

  @media (min-width: 1024px) {
    .col-lg {
      display: block;
    }
  }

  /* Sin animación: lista estática y legible, sin duplicados ni recorte. */
  @media (prefers-reduced-motion: reduce) {
    .rev-cols {
      max-height: none;
      overflow: visible;
      -webkit-mask-image: none;
      mask-image: none;
      flex-wrap: wrap;
    }
    .rev-col-track {
      animation: none;
      padding-bottom: 0;
    }
    .rev-card[data-dup] {
      display: none;
    }
  }
</style>
