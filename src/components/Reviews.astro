---
import { Icon } from 'astro-icon/components';

// NOTA: reseñas de ejemplo. Sustituir por las reales (Google, redes...) manteniendo
// la estructura del array `reviews`.
const reviews = [
  {
    text: 'El cordero a la brasa está espectacular y el trato es como en casa. Volvemos siempre que pasamos por El Bonillo.',
    author: 'María G.',
    origin: 'Google',
    rating: 5,
  },
  {
    text: 'Menú del día con producto de la tierra y a un precio inmejorable. Las gachas manchegas, de diez.',
    author: 'Antonio R.',
    origin: 'Google',
    rating: 5,
  },
  {
    text: 'Ambiente de pueblo, terraza estupenda y unos almuerzos de los de antes. El atascaburras está para repetir.',
    author: 'Lucía M.',
    origin: 'Facebook',
    rating: 5,
  },
];

const ratingAvg = '4,8';
const ratingCount = '120+';
---

<section id="resenas" class="rev-section">
  <div class="rev-inner">
    <header class="rev-head reveal">
      <p class="eyebrow">• Lo que dicen •</p>
      <h2 class="section-title">La gente del pueblo lo tiene claro</h2>
      <div class="rev-score">
        <span class="rev-stars" aria-hidden="true">
          {Array.from({ length: 5 }).map(() => <Icon name="lucide:star" class="rev-star" />)}
        </span>
        <span class="rev-score-text">
          <strong>{ratingAvg}</strong> de media · {ratingCount} reseñas
        </span>
      </div>
    </header>

    <div class="rev-grid">
      {reviews.map((rev, i) => (
        <figure class="rev-card reveal" style={`--reveal-delay:${i * 100}ms`}>
          <span class="rev-quote" aria-hidden="true"><Icon name="lucide:quote" /></span>
          <span class="rev-card-stars" aria-label={`${rev.rating} de 5 estrellas`}>
            {Array.from({ length: rev.rating }).map(() => (
              <Icon name="lucide:star" class="rev-star" />
            ))}
          </span>
          <blockquote class="rev-text">{rev.text}</blockquote>
          <figcaption class="rev-author">
            <span class="rev-name">{rev.author}</span>
            <span class="rev-origin">{rev.origin}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .rev-section {
    background: linear-gradient(180deg, var(--color-secondary) 0%, var(--color-bg) 35%, var(--color-bg) 100%);
    padding: 5rem 1.5rem;
  }

  .rev-inner {
    max-width: 72rem;
    margin: 0 auto;
  }

  .rev-head {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .rev-score {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1.25rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--color-accent-25);
  }

  .rev-stars {
    display: inline-flex;
    gap: 0.1rem;
  }

  .rev-star {
    width: 1rem;
    height: 1rem;
    color: var(--color-accent);
    fill: var(--color-accent);
  }

  .rev-score-text {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  .rev-score-text strong {
    color: var(--color-text);
    font-family: var(--font-sans-semibold);
  }

  .rev-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .rev-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem 1.75rem 1.75rem;
    border-radius: 1.5rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    transition:
      border-color 0.3s ease,
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .rev-card:hover {
    border-color: var(--color-accent-25);
    transform: translateY(-3px);
    box-shadow: 0 18px 40px -28px rgba(0, 0, 0, 0.9);
  }

  .rev-quote {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    color: var(--color-accent-25);
  }

  .rev-quote :global(svg) {
    width: 2rem;
    height: 2rem;
  }

  .rev-card-stars {
    display: inline-flex;
    gap: 0.15rem;
  }

  .rev-text {
    color: var(--color-text);
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .rev-author {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .rev-name {
    color: var(--color-text);
    font-family: var(--font-sans-semibold);
    font-size: 0.95rem;
  }

  .rev-origin {
    color: var(--color-text-secondary);
    font-size: 0.8rem;
  }

  @media (min-width: 768px) {
    .rev-section {
      padding: 7rem 3rem;
    }
    .rev-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
