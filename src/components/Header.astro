---
import { Icon } from 'astro-icon/components';

const path = Astro.url.pathname;
const isHome = path === '/' || path === '';
const onCarta = path.startsWith('/carta');

// `mobileHide`: secundarios que se ocultan en móvil para que la barra no se
// comprima (siguen visibles en escritorio). Esenciales quedan siempre.
const links = [
    { label: 'Inicio', spy: 'inicio', icon: 'lucide:home' },
    { label: 'Especialidades', spy: 'especialidades', icon: 'lucide:utensils-crossed' },
    { label: 'Novedades', spy: 'wondercool', icon: 'lucide:sparkles', mobileHide: true },
    { label: 'Galería', spy: 'galeria', icon: 'lucide:image' },
    { label: 'Carta', spy: 'carta', page: '/carta', icon: 'lucide:book-open', cta: true },
    { label: 'Reseñas', spy: 'resenas', icon: 'lucide:star', mobileHide: true },
    { label: 'Horarios', spy: 'horarios', icon: 'lucide:clock' },
    { label: 'Ubicación', spy: 'ubicacion', icon: 'lucide:map-pin' },
    { label: 'Contacto', spy: 'contacto', icon: 'lucide:phone' },
];

// Las anclas funcionan en cualquier página: dentro del home son #id,
// fuera (p.ej. /carta) saltan al home con /#id. "Carta" es página propia.
const hrefFor = (l: typeof links[number]) =>
    l.page ?? (isHome ? `#${l.spy}` : `/#${l.spy}`);
const activeSpy = onCarta ? 'carta' : 'inicio';
---

<header
    id="tube-navbar"
    class="fixed top-0 left-1/2 -translate-x-1/2 z-50 pt-3 sm:pt-6 pointer-events-none px-2 sm:px-4 max-w-full"
>
    <nav class="tube-nav relative pointer-events-auto flex items-center gap-1 sm:gap-2 bg-secondary/80 border border-white/10 backdrop-blur-lg py-1 px-1 rounded-full shadow-lg">
        <!-- Lámpara deslizante (efecto tubelight) -->
        <span id="tube-lamp" class="tube-lamp" aria-hidden="true">
            <span class="tube-lamp-bar">
                <span class="tube-glow tube-glow-1"></span>
                <span class="tube-glow tube-glow-2"></span>
                <span class="tube-glow tube-glow-3"></span>
            </span>
        </span>

        {links.map((link) => (
            <a
                href={hrefFor(link)}
                data-tube-link
                data-spy={link.spy}
                class:list={['tube-link', { 'is-active': link.spy === activeSpy, 'tube-cta': link.cta, 'tube-mobile-hide': link.mobileHide }]}
                aria-label={link.cta ? `${link.label} — ver el menú` : undefined}
            >
                <span class="hidden md:inline">{link.label}</span>
                <span class="md:hidden flex items-center justify-center">
                    <Icon name={link.icon} class="w-[18px] h-[18px]" />
                </span>
            </a>
        ))}
    </nav>
</header>

<style>
    .tube-link {
        position: relative;
        cursor: pointer;
        font-size: 0.875rem;
        font-weight: 600;
        /* Padding lateral ajustado en móvil (solo iconos) para que los 8
           entren sin cortarse en pantallas estrechas como el S23. */
        padding: 0.5rem 0.55rem;
        border-radius: 9999px;
        color: rgb(225 220 201 / 0.8);
        transition: color 0.2s ease;
        z-index: 1;
        white-space: nowrap;
    }
    @media (min-width: 768px) {
        .tube-link { padding: 0.5rem 1.25rem; }
    }

    /* Móvil: respeta el notch / barra de estado superior. Al ocultar los ítems
       secundarios solo quedan 5 iconos, así que la barra respira sin apreturas. */
    @media (max-width: 767px) {
        /* Solo los esenciales en móvil; el resto vuelve en escritorio. */
        .tube-mobile-hide {
            display: none;
        }
    }
    @media (max-width: 639px) {
        #tube-navbar {
            padding-top: calc(0.75rem + env(safe-area-inset-top, 0px));
            padding-left: 0.25rem;
            padding-right: 0.25rem;
        }
        .tube-nav {
            gap: 0;
        }
        .tube-link {
            padding: 0.5rem 0.4rem;
        }
    }
    .tube-link:hover,
    .tube-link.is-active {
        color: var(--color-accent);
    }

    /* Botón destacado de Carta: dorado de marca para que se lea como la
       acción principal entre el resto de iconos. Texto oscuro en todos
       los estados (si no, el color "activo" lo dejaría ilegible). */
    .tube-link.tube-cta {
        background: var(--color-accent);
        color: #1a120a;
        font-weight: 700;
        box-shadow: 0 4px 16px -4px rgb(201 169 97 / 0.6);
    }
    .tube-link.tube-cta:hover,
    .tube-link.tube-cta.is-active {
        color: #1a120a;
        filter: brightness(1.07);
    }
    /* Latido suave un par de veces al entrar, para que la vista vaya ahí. */
    .tube-link.tube-cta {
        animation: cta-pulse 2.2s ease-in-out 0.6s 2;
    }
    @keyframes cta-pulse {
        0%, 100% { box-shadow: 0 4px 16px -4px rgb(201 169 97 / 0.6); }
        50% { box-shadow: 0 4px 22px 0 rgb(201 169 97 / 0.85); }
    }
    @media (prefers-reduced-motion: reduce) {
        .tube-link.tube-cta { animation: none; }
    }

    /* Lámpara: pastilla + barra superior con glow */
    .tube-lamp {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        background: rgb(201 169 97 / 0.08);
        border-radius: 9999px;
        z-index: 0;
        opacity: 0;
        transform: translateX(0);
        transition:
            transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
            width 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
            opacity 0.2s ease;
        pointer-events: none;
    }
    .tube-lamp.ready { opacity: 1; }

    .tube-lamp-bar {
        position: absolute;
        top: -0.5rem;
        left: 50%;
        transform: translateX(-50%);
        width: 2rem;
        height: 0.25rem;
        background: var(--color-accent);
        border-top-left-radius: 9999px;
        border-top-right-radius: 9999px;
    }
    .tube-glow {
        position: absolute;
        background: rgb(201 169 97 / 0.25);
        border-radius: 9999px;
    }
    .tube-glow-1 { width: 3rem; height: 1.5rem; filter: blur(12px); top: -0.5rem; left: -0.5rem; }
    .tube-glow-2 { width: 2rem; height: 1.5rem; filter: blur(12px); top: -0.25rem; }
    .tube-glow-3 { width: 1rem; height: 1rem; filter: blur(4px); top: 0; left: 0.5rem; }
</style>

<script>
    const links = Array.from(
        document.querySelectorAll<HTMLAnchorElement>('[data-tube-link]'),
    );
    const lamp = document.getElementById('tube-lamp');
    const nav = document.querySelector<HTMLElement>('.tube-nav');

    const moveLamp = (el: HTMLElement) => {
        if (!lamp) return;
        // Si el enlace está oculto (secundario en móvil) no movemos la lámpara.
        if (el.offsetParent === null) return;
        lamp.style.width = `${el.offsetWidth}px`;
        lamp.style.transform = `translateX(${el.offsetLeft}px)`;
        lamp.classList.add('ready');
    };

    const setActive = (el: HTMLElement) => {
        links.forEach((l) => l.classList.toggle('is-active', l === el));
        moveLamp(el);
    };

    // Posición inicial
    const initial = links.find((l) => l.classList.contains('is-active')) ?? links[0];
    if (initial) requestAnimationFrame(() => moveLamp(initial));

    links.forEach((link) => {
        link.addEventListener('click', () => setActive(link));
    });

    // Scrollspy: marca activa la sección visible (solo donde existan las secciones)
    const byTarget = new Map<string, HTMLElement>();
    links.forEach((l) => {
        const id = l.dataset.spy;
        if (id) byTarget.set(id, l);
    });

    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    const link = byTarget.get(entry.target.id);
                    if (link) setActive(link);
                }
            });
        },
        { rootMargin: '-45% 0px -45% 0px', threshold: 0 },
    );
    byTarget.forEach((_, id) => {
        const section = document.getElementById(id);
        if (section) observer.observe(section);
    });

    // Recolocar la lámpara al redimensionar
    window.addEventListener('resize', () => {
        const active = links.find((l) => l.classList.contains('is-active'));
        if (active) moveLamp(active);
    });
</script>
