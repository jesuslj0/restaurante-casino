---
import { Icon } from 'astro-icon/components';
---

<header id="header-container" class="fixed top-4 left-0 right-0 z-50 flex justify-center pointer-events-none">
    <!-- Menú desktop -->
    <nav class="hidden md:flex pointer-events-auto px-8 py-3 bg-secondary rounded-full shadow-lg">
        <ul class="flex items-center justify-center gap-8">
            <li><a href="#" class="text-text hover:text-accent hover:text-shadow-md">Inicio</a></li>
            <li><a href="#" class="text-text hover:text-accent hover:text-shadow-md">Carta</a></li>
            <li><a href="#" class="text-text hover:text-accent hover:text-shadow-md">Menús</a></li>
            <li><a href="#" class="text-text hover:text-accent hover:text-shadow-md">Reservas</a></li>
            <li><a href="#" class="text-text hover:text-accent hover:text-shadow-md">Contacto</a></li>
        </ul>
    </nav>

    <!-- Menú móvil -->
    <div class="mobile-menu md:hidden pointer-events-auto absolute right-4">
        <!-- Botón hamburguesa -->
        <button id="menu-toggle" aria-label="Abrir menú" class="flex items-center justify-center w-11 h-11 bg-secondary rounded-full shadow-lg text-text">
            <Icon name="lucide:menu" id="icon-open" class="w-5 h-5" />
            <Icon name="lucide:x" id="icon-close" class="w-5 h-5 hidden" />
        </button>

        <!-- Panel desplegable -->
        <nav id="mobile-nav" class="hidden mt-2 bg-secondary rounded-2xl shadow-lg px-6 py-4">
            <ul class="flex flex-col gap-4">
                <li><a href="#" class="text-text hover:text-accent block py-1">Inicio</a></li>
                <li><a href="#" class="text-text hover:text-accent block py-1">Carta</a></li>
                <li><a href="#" class="text-text hover:text-accent block py-1">Menús</a></li>
                <li><a href="#" class="text-text hover:text-accent block py-1">Reservas</a></li>
                <li><a href="#" class="text-text hover:text-accent block py-1">Contacto</a></li>
            </ul>
        </nav>
    </div>
</header>

<script>
    const toggle = document.getElementById('menu-toggle');
    const nav = document.getElementById('mobile-nav');
    const iconOpen = document.getElementById('icon-open');
    const iconClose = document.getElementById('icon-close');

    toggle?.addEventListener('click', () => {
        const isOpen = !nav?.classList.contains('hidden');
        nav?.classList.toggle('hidden', isOpen);
        iconOpen?.classList.toggle('hidden', !isOpen);
        iconClose?.classList.toggle('hidden', isOpen);
    });
</script>
