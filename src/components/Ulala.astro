---
import { Icon } from 'astro-icon/components';

// Sabores destacados: comunican la variedad (fruta, cremosos, rellenos y con alcohol).
const flavors = [
  'Mango',
  'Sandía',
  'Mojito',
  'Tinto de verano',
  'Coco y leche condensada',
  'Fresa con Nutella',
  'Café bombón',
  'Maracuyá',
];

const price = '3,50 €';
const videoSrc = '/videoscrub/helados-scrub.mp4';
---

<!-- Escritorio: la sección alta es la "pista" de scroll y el vídeo (sticky)
     avanza fotograma a fotograma con el scroll. Móvil: bloque normal con el
     vídeo en bucle (autoplay loop). El sticky cuelga directo de <main>, sin
     ancestros con filter/transform que lo rompan. -->
<section id="helados" class="ula-section" aria-label="Helados ULALÁ">
  <div class="ula-sticky">
    <video
      class="ula-video"
      src={videoSrc}
      poster="/videoscrub/helados-poster.jpg"
      muted
      playsinline
      preload="auto"
      aria-hidden="true"
    ></video>

    <div class="ula-veil" aria-hidden="true"></div>

    <div class="ula-content">
      <p class="ula-eyebrow reveal">• Novedad · Solo en verano •</p>

      <h2 class="ula-title reveal" style="--reveal-delay:80ms">
        El verano sabe a <span class="ula-brand">ULALÁ</span>
      </h2>

      <p class="ula-lead reveal" style="--reveal-delay:160ms">
        Helados artesanales de fruta 100% natural, sin aditivos ni conservantes.
        De fruta, cremosas, rellenas o con un toque de alcohol: frescura y sabor
        auténtico en cada bocado.
      </p>

      <ul class="ula-flavors reveal" style="--reveal-delay:240ms">
        {flavors.map((f) => (
          <li class="ula-chip">{f}</li>
        ))}
      </ul>

      <div class="ula-cta reveal" style="--reveal-delay:320ms">
        <span class="ula-price">
          {price}<small>/ helado</small>
        </span>
        <a href="/#contacto" class="primary-btn ula-btn">
          Pruébalos este verano <Icon name="lucide:arrow-right" />
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /* Móvil (base): bloque normal a pantalla; el vídeo se reproduce en bucle.
     En escritorio (media query) pasa a ser la "pista" de scroll del scrub. */
  .ula-section {
    position: relative;
  }

  .ula-sticky {
    position: relative;
    /* Móvil: columna flex con el contenido anclado abajo. min-height (no
       height fijo) deja que la sección crezca si el texto no cabe, así nunca
       se recorta el eyebrow ni el título por arriba. */
    min-height: 100svh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    /* Teal de la escena de la carta: cualquier carga del vídeo se funde con
       el fondo fotográfico de la página. */
    background: #0e1411;
  }

  .ula-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    /* Capa GPU propia: evita que el navegador re-rasterice el vídeo en cada
       frame de scroll (causa de los parpadeos / "cambios de luz"). */
    transform: translateZ(0);
    backface-visibility: hidden;
    will-change: transform;
  }

  /* Velo: oscurece la franja inferior para que el texto sea legible y deja
     ver los helados (parte superior). Funde arriba y abajo con el fondo. */
  .ula-veil {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      /* Borde inferior: funde largo y muy gradual al teal de la carta (bloque
         de vinos) y oscurece la franja para que el texto sea legible. */
      linear-gradient(
        to top,
        #0e1411 0%,
        rgba(14, 20, 17, 0.96) 6%,
        rgba(12, 17, 18, 0.82) 18%,
        rgba(8, 14, 20, 0.55) 34%,
        rgba(5, 12, 20, 0.22) 52%,
        rgba(5, 12, 20, 0) 72%
      ),
      /* Borde superior: funde largo y muy gradual al teal de la carta (postres). */
      linear-gradient(
        to bottom,
        #0e1411 0%,
        rgba(14, 20, 17, 0.9) 5%,
        rgba(14, 20, 17, 0.6) 14%,
        rgba(14, 20, 17, 0.32) 26%,
        rgba(14, 20, 17, 0.12) 38%,
        rgba(14, 20, 17, 0) 50%
      );
  }

  .ula-content {
    /* Móvil: en flujo (no absolute) para que no se recorte. Padding inferior
       amplio para librar el navbar flotante inferior del móvil. */
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 72rem;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .ula-eyebrow {
    color: var(--color-accent);
    font-family: var(--font-sans-semibold);
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin: 0;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.95), 0 0 2px rgba(0, 0, 0, 0.8);
  }

  .ula-title {
    font-family: var(--font-serif-semibold);
    color: var(--color-text);
    font-size: clamp(2rem, 1.3rem + 3.4vw, 3.5rem);
    line-height: 1.08;
    margin: 0.75rem 0 0;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.75), 0 1px 3px rgba(0, 0, 0, 0.6);
  }

  /* Guiño a los colores de marca ULALÁ (rojo, amarillo, turquesa). El
     drop-shadow le da un halo oscuro para que se lea aunque caiga sobre un
     polo de color similar (p. ej. la sandía). */
  .ula-brand {
    background: linear-gradient(95deg, #ef5566 0%, #f4a300 45%, #36d6c6 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    font-style: normal;
    filter: drop-shadow(0 2px 7px rgba(0, 0, 0, 0.7));
  }

  .ula-lead {
    color: var(--color-text);
    font-size: clamp(1rem, 0.95rem + 0.4vw, 1.2rem);
    line-height: 1.65;
    max-width: 38rem;
    margin: 1rem 0 0;
    opacity: 0.92;
    text-shadow: 0 1px 16px rgba(0, 0, 0, 0.6);
  }

  .ula-flavors {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
  }

  .ula-chip {
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-family: var(--font-sans-semibold);
    color: var(--color-text);
    border: 1px solid rgba(255, 255, 255, 0.18);
    /* Fondo semisólido en vez de backdrop-filter: el blur sobre el vídeo
       fuerza un re-muestreo en cada frame de scroll y provoca parpadeos. */
    background: rgba(8, 14, 22, 0.55);
  }

  .ula-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 2rem;
  }

  .ula-price {
    display: inline-flex;
    align-items: baseline;
    gap: 0.3rem;
    font-family: var(--font-serif-semibold);
    font-size: 1.75rem;
    color: var(--color-accent);
  }

  .ula-price small {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .ula-btn :global(svg) {
    transition: transform 0.25s ease;
  }
  .ula-btn:hover :global(svg) {
    transform: translateX(3px);
  }

  /* Móvil: el vídeo vertical ocupa toda la pantalla, así que los cortes con
     los bloques de la carta (Postres arriba, Vinos abajo) se notan más.
     Fade mucho más largo y con muchas paradas (curva casi 'ease') para una
     transición suave y sombreada que disimule el corte por completo. */
  @media (max-width: 767px) {
    .ula-veil {
      background:
        /* Borde inferior (texto + fusión con Vinos): muchas paradas para una
           transición sombreada y suave, sin bandas. */
        linear-gradient(
          to top,
          #0e1411 0%,
          rgba(14, 20, 17, 0.96) 4%,
          rgba(13, 18, 19, 0.82) 11%,
          rgba(11, 16, 19, 0.6) 20%,
          rgba(8, 14, 20, 0.4) 30%,
          rgba(6, 13, 20, 0.22) 42%,
          rgba(5, 12, 20, 0.08) 54%,
          rgba(5, 12, 20, 0) 66%
        ),
        /* Borde superior (fusión con Postres): mismo fundido suave. */
        linear-gradient(
          to bottom,
          #0e1411 0%,
          rgba(14, 20, 17, 0.95) 4%,
          rgba(14, 20, 17, 0.8) 9%,
          rgba(14, 20, 17, 0.58) 16%,
          rgba(14, 20, 17, 0.36) 24%,
          rgba(14, 20, 17, 0.18) 32%,
          rgba(14, 20, 17, 0.06) 40%,
          rgba(14, 20, 17, 0) 48%
        );
    }

    /* Bloque de texto más compacto en móvil: así queda holgado en la zona
       baja y su parte superior (eyebrow + título) no sube hasta el nav fijo
       de arriba, que lo tapaba. */
    .ula-title {
      font-size: clamp(1.7rem, 1.2rem + 3vw, 2.4rem);
      margin-top: 0.4rem;
    }
    .ula-lead {
      margin-top: 0.6rem;
      font-size: 0.95rem;
      line-height: 1.5;
    }
    .ula-flavors {
      margin-top: 0.9rem;
      gap: 0.4rem;
    }
    .ula-chip {
      padding: 0.32rem 0.7rem;
      font-size: 0.72rem;
    }
    .ula-cta {
      margin-top: 1.1rem;
      gap: 0.9rem;
    }
    .ula-price {
      font-size: 1.5rem;
    }
  }

  @media (min-width: 768px) {
    /* Escritorio: pista alta (100vh fijos + recorrido) y vídeo fijo (sticky)
       que avanza fotograma a fotograma con el scroll. */
    .ula-section {
      height: 220vh;
    }
    .ula-sticky {
      position: sticky;
      top: 0;
      height: 100vh;
      min-height: 0;
      display: block;
    }
    .ula-content {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      align-items: flex-start;
      text-align: left;
      padding: 0 3rem 5rem;
    }
    .ula-flavors {
      justify-content: flex-start;
    }
    .ula-cta {
      justify-content: flex-start;
    }
  }

  /* Sin scrub para quien prefiere menos movimiento: vídeo quieto en un
     fotograma con algo de derretido y contenido siempre visible. */
  @media (prefers-reduced-motion: reduce) {
    .ula-section {
      height: auto;
    }
    .ula-sticky {
      position: relative;
      height: auto;
      min-height: 100svh;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
    }
    .ula-content {
      position: relative;
      left: auto;
      right: auto;
      bottom: auto;
      padding: 2.5rem 1.5rem 3rem;
    }
  }
</style>

<script>
  const section = document.getElementById('helados');
  const video = section?.querySelector<HTMLVideoElement>('.ula-video');

  if (section && video) {
    const reduceMq = window.matchMedia('(prefers-reduced-motion: reduce)');
    const desktopMq = window.matchMedia('(min-width: 768px)');

    let duration = video.duration || 0;
    const onMeta = () => { duration = video.duration || 0; };
    if (video.readyState >= 1) onMeta();
    video.addEventListener('loadedmetadata', onMeta);

    // El "seek" fino en táctil (iOS/iPad) necesita decodificar antes: cebamos
    // con play()/pause(). En no-táctil se da por cebado (nunca se llama play()).
    const isTouch = window.matchMedia('(pointer: coarse)').matches;
    let primed = !isTouch;

    // Dos fuentes: horizontal 16:9 para el scrub de escritorio, vertical 9:16
    // para el bucle en móvil (así se ven todos los helados sin recortar).
    const SRC_SCRUB = '/videoscrub/helados-scrub.mp4';
    const SRC_LOOP = '/videoscrub/helados-loop-9x16.mp4';
    const setSource = (url: string) => {
      if (video.getAttribute('src') === url) return;
      video.setAttribute('src', url);
      duration = 0; // se recalcula en loadedmetadata del nuevo vídeo
      video.load();
    };

    // ---------- MODO LOOP (móvil): autoplay en bucle ----------
    const enableLoop = () => {
      video.loop = true;
      video.muted = true;
      const p = video.play();
      if (p && typeof p.catch === 'function') p.catch(() => {});
    };
    const disableLoop = () => {
      video.loop = false;
      video.pause();
    };

    // ---------- MODO SCRUB (escritorio): avanza con el scroll ----------
    let target = 0;
    let current = 0;
    let rafId: number | null = null;
    let io: IntersectionObserver | null = null;
    let scrollHandler: (() => void) | null = null;
    let resizeHandler: (() => void) | null = null;
    let touchHandler: (() => void) | null = null;

    const prime = () => {
      if (primed) return;
      primed = true;
      const p = video.play();
      if (p && typeof p.then === 'function') {
        p.then(() => {
          video.pause();
          try { video.currentTime = current; } catch {}
        }).catch(() => {});
      } else {
        video.pause();
      }
    };

    const computeTarget = () => {
      const rect = section.getBoundingClientRect();
      const total = section.offsetHeight - window.innerHeight;
      const scrolled = Math.min(Math.max(-rect.top, 0), total);
      const progress = total > 0 ? scrolled / total : 0;
      target = progress * (duration || 0);
    };

    const loop = () => {
      current += (target - current) * 0.25; // lerp → scrub fluido y con respuesta
      if (Math.abs(target - current) < 0.005) current = target;
      // Solo pedimos un nuevo "seek" si el anterior ya terminó (evita tirones).
      if (duration && video.readyState >= 2 && !video.seeking) {
        if (Math.abs(video.currentTime - current) > 0.01) {
          try { video.currentTime = current; } catch {}
        }
      }
      rafId = requestAnimationFrame(loop);
    };
    const startRaf = () => { if (rafId == null) rafId = requestAnimationFrame(loop); };
    const stopRaf = () => { if (rafId != null) { cancelAnimationFrame(rafId); rafId = null; } };

    const enableScrub = () => {
      video.loop = false;
      video.pause();
      current = 0;
      target = 0;
      scrollHandler = () => { prime(); computeTarget(); };
      resizeHandler = () => computeTarget();
      touchHandler = () => prime();
      window.addEventListener('scroll', scrollHandler, { passive: true });
      window.addEventListener('resize', resizeHandler, { passive: true });
      window.addEventListener('touchstart', touchHandler, { passive: true });
      if ('IntersectionObserver' in window) {
        io = new IntersectionObserver((entries) => {
          entries.forEach((entry) => (entry.isIntersecting ? startRaf() : stopRaf()));
        });
        io.observe(section);
      } else {
        startRaf();
      }
      computeTarget();
    };
    const disableScrub = () => {
      stopRaf();
      if (io) { io.disconnect(); io = null; }
      if (scrollHandler) { window.removeEventListener('scroll', scrollHandler); scrollHandler = null; }
      if (resizeHandler) { window.removeEventListener('resize', resizeHandler); resizeHandler = null; }
      if (touchHandler) { window.removeEventListener('touchstart', touchHandler); touchHandler = null; }
    };

    // ---------- MODO ESTÁTICO (reduce-motion): un fotograma quieto ----------
    const enableStatic = () => {
      video.loop = false;
      video.pause();
      const setFrame = () => { try { video.currentTime = (duration || 0) * 0.35; } catch {} };
      if (duration) setFrame();
      else video.addEventListener('loadedmetadata', setFrame, { once: true });
    };

    // ---------- Selección de modo (y reconfiguración al cambiar) ----------
    const configure = () => {
      disableScrub();
      disableLoop();
      if (reduceMq.matches) {
        setSource(desktopMq.matches ? SRC_SCRUB : SRC_LOOP);
        enableStatic();
      } else if (desktopMq.matches) {
        setSource(SRC_SCRUB);
        enableScrub();
      } else {
        setSource(SRC_LOOP);
        enableLoop();
      }
    };

    configure();
    desktopMq.addEventListener('change', configure);
    reduceMq.addEventListener('change', configure);
  }
</script>
