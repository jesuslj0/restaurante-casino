---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import logo from "../assets/img/logo-casino.png";
import bgImage from "../assets/img/Herocasino.png";

interface Props {
  title: string;
  subtitle: string;
  buttonText: string;
  buttonSecondaryText: string;
  restaurantName: string;
  location: string;
  schedule: string;
}

const { title, subtitle, buttonText, buttonSecondaryText, restaurantName, location, schedule } = Astro.props;
---

<div id="inicio" class="hero-background" style={`background-image: url(${bgImage.src})`}>
  <section>
    <div class="hero-inner">
      <div class="hero-content">
        <div class="logo-wrapper">
          <Image 
            src={logo}
            alt=`Logo ${restaurantName}` 
            class="hero-logo" 
            loading="eager"
            fetchpriority="high"
          />
        </div>

        <div class="hero-text">
          <p class="hero-eyebrow font-sans-semibold tracking-widest uppercase text-xs mb-3">
            • {restaurantName} •
          </p>
          <h1 class="hero-title text-text text-4xl md:text-6xl leading-tight mb-4" set:html={title.replace('Plaza Mayor', '<span class="title-highlight">Plaza Mayor</span>')}>
          </h1>
          <p class="text-text-secondary font-sans text-base opacity-80 mb-8 max-w-md">
            {subtitle}
          </p>
          <div class="hero-buttons flex gap-2 ">
            <a href="#contacto" class="primary-btn">
              {buttonText} <Icon name="lucide:calendar-days" />
            </a>
            <a href="/carta" class="secondary-btn">
              {buttonSecondaryText} <Icon name="lucide:book-open"/>
            </a>
          </div>
        </div>
      </div>

      <div class="hero-info justify-center mt-5 mb-7">
        <div class="info-chip text-text text-sm bg-white/5 backdrop-blur-sm inline-flex items-center gap-2 py-4 px-6 rounded-xl">
          <Icon name="lucide:map-pin" />
          <span>{location}</span>
        </div>
        <div class="info-chip text-text text-sm bg-white/5 backdrop-blur-sm inline-flex items-center gap-2 py-4 px-6 rounded-xl">
          <Icon name="lucide:clock-8" />
          <span>{schedule}</span>
        </div>
      </div>
    </div>
  </section>
</div>


<style>
  /* Chip con borde metalizado (degradado oro → cobre del proyecto) */
  .hero-eyebrow {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    position: relative;
    background:
      linear-gradient(135deg, #4a3a14 0%, #6e561d 45%, #3a2c10 100%) padding-box,
      linear-gradient(135deg,
        var(--color-accent) 0%,
        #f3e3b0 25%,
        var(--color-accent-2) 50%,
        #f3e3b0 75%,
        var(--color-accent) 100%) border-box;
    border: 1px solid transparent;
    color: #f3e3b0;
    font-size: 0.68rem;
    text-shadow: 0 1px 1px rgba(0, 0, 0, 0.45);
    box-shadow:
      0 1px 0 rgba(255, 240, 200, 0.15) inset,
      0 -1px 2px rgba(0, 0, 0, 0.4) inset,
      0 4px 14px rgba(0, 0, 0, 0.35);
  }

  .hero-background {
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
  }

  section {
    background:
      linear-gradient(
        to bottom, rgba(0,0,0,0.75) 0%, transparent 25%,  transparent 60%,
        rgba(10,10,10,0.85) 88%, var(--color-bg) 100%)
      rgba(0, 0, 0, 0.55);
    /* min-height (no height fijo): si el contenido no cabe en pantallas
       pequeñas, crece en vez de recortar el logo por arriba. */
    min-height: 100dvh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }


  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    /* Gaps compactos en móvil; se agrandan en escritorio (media query). */
    gap: 2.5rem;
    width: 100%;
    max-width: 72rem;
    /* Padding inferior amplio para que los chips no queden bajo el navbar. */
    padding: 6rem 1.5rem 3rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
  }

  .logo-wrapper {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-logo {
    width: 160px;
    height: 160px;
    object-fit: contain;
    border-radius: 100%;
    transition:
      transform 0.3s ease,
      filter 0.3s ease;
  }

  .hero-logo:hover {
    transform: translateY(-2px);
    filter: drop-shadow(0 8px 20px var(--color-accent-25));
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
  }

  .hero-title {
    font-family: "Fraunces", serif;
    font-weight: 600;
  }

  .hero-text :global(.title-highlight) {
    color: rgb(232 210 150);
  }

  .hero-buttons {
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .hero-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 100%;
  }

  .info-chip {
    border: 1px solid transparent;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .info-chip:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 14px var(--color-accent-25);
  }

  @media (min-width: 768px) {
    .hero-inner {
      gap: 6rem;
      padding: 2rem 3rem;
    }

    .hero-content {
      flex-direction: row;
      align-items: center;
      gap: 3rem;
    }

    .hero-logo {
      width: 280px;
      height: 280px;
    }

    .hero-text {
      align-items: flex-start;
      text-align: left;
    }

    .hero-buttons {
      justify-content: flex-start;
    }

    .hero-info {
      flex-direction: row;
      gap: 2rem;
    }
  }
</style>