---
import entrada from '../assets/img/casino-entrada.png';
import gente from '../assets/img/local-gente.png';

// Galería editorial: cada fila alterna imagen y texto. La primera es la fachada.
const slides = [
  {
    src: entrada.src,
    alt: 'Fachada de El Casino en la Plaza Mayor',
    title: 'La fachada de siempre',
    desc: 'En plena Plaza Mayor, un lugar con mucha historia.',
  },
  {
    src: '/images/20260609_123711.jpg',
    alt: 'El salón de El Casino',
    title: 'El salón',
    desc: 'Amplio y acogedor, para comer agusto y sin prisas.',
  },
  {
    src: '/images/20260609_123728.jpg',
    alt: 'Mesas preparadas en El Casino',
    title: 'Mesa puesta',
    desc: 'Lista para celebraciones, comidas familiares o el menú del día.',
  },
  {
    src: '/images/20260609_123750.jpg',
    alt: 'Interior de El Casino',
    title: 'Nuestro interior',
    desc: 'Detalles de toda la vida con un aire actual.',
  },
  {
    src: '/images/20260609_123844.jpg',
    alt: 'Barra e iluminación de El Casino',
    title: 'La barra',
    desc: 'Para un café, una caña o una buena charla.',
  },
  {
    src: gente.src,
    alt: 'Gente disfrutando en El Casino',
    title: 'Momentos',
    desc: 'Lo que de verdad se queda: la gente.',
  },
];
---

<section id="galeria" class="gal-section">
  <div class="gal-inner">
    <header class="gal-head reveal">
      <p class="eyebrow">• Galería •</p>
      <h2 class="section-title">Un paseo por <span class="title-highlight">El Casino</span></h2>
      <p class="section-lead">Un vistazo a los rincones donde pasa todo.</p>
    </header>

    <div class="gal-rows">
      {slides.map((s, i) => (
        <article class="gal-row reveal" style={`--reveal-delay:${(i % 2) * 120}ms`}>
          <figure class="gal-figure">
            <img
              src={s.src}
              alt={s.alt}
              class="gal-img"
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async"
            />
          </figure>
          <div class="gal-copy">
            <span class="gal-num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="gal-title">{s.title}</h3>
            <p class="gal-desc">{s.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .gal-section {
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-secondary) 40%, var(--color-secondary) 100%);
    padding: 5rem 0;
  }

  .gal-inner {
    max-width: 76rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .gal-head {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .gal-rows {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .gal-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: center;
  }

  /* ---------- Imagen cinematográfica ---------- */
  .gal-figure {
    margin: 0;
    position: relative;
    overflow: hidden;
    border-radius: 1.25rem;
    aspect-ratio: 16 / 10;
    border: 1px solid rgba(255, 255, 255, 0.07);
    box-shadow: 0 30px 70px -40px rgba(0, 0, 0, 0.95);
  }

  .gal-figure::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10, 10, 10, 0.5) 0%, transparent 50%);
    pointer-events: none;
  }

  .gal-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .gal-row:hover .gal-img {
    transform: scale(1.05);
  }

  /* ---------- Texto ---------- */
  .gal-copy {
    padding: 0 0.25rem;
  }

  .gal-num {
    display: block;
    font-family: var(--font-serif);
    font-size: 1rem;
    letter-spacing: 0.1em;
    color: var(--color-accent-2);
    margin-bottom: 0.6rem;
  }

  .gal-title {
    font-family: var(--font-serif-semibold);
    font-weight: 500;
    font-size: clamp(1.6rem, 1.2rem + 1.6vw, 2.4rem);
    line-height: 1.1;
    color: var(--color-text);
    margin: 0 0 0.7rem;
  }

  .gal-desc {
    color: var(--color-text-secondary);
    font-size: 1.02rem;
    line-height: 1.6;
    margin: 0;
    max-width: 32rem;
  }

  @media (min-width: 768px) {
    .gal-section { padding: 7rem 0; }
    .gal-inner { padding: 0 3rem; }

    .gal-rows { gap: 6rem; }

    .gal-row {
      grid-template-columns: 1.15fr 0.85fr;
      gap: 3.5rem;
    }

    .gal-figure { aspect-ratio: 3 / 2; }

    /* Filas pares: imagen a la derecha, texto a la izquierda */
    .gal-row:nth-child(even) .gal-figure { order: 2; }
    .gal-row:nth-child(even) .gal-copy { order: 1; }
    .gal-row:nth-child(even) .gal-desc { margin-left: auto; }
    .gal-row:nth-child(even) .gal-copy { text-align: right; }
  }
</style>
