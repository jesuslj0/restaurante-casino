---
import { Icon } from 'astro-icon/components';

interface Dish {
  tag: string;
  name: string;
  desc?: string;
  price: string;
}

const menuDelDia = {
  price: '13,50 €',
  days: 'De lunes a viernes · mediodía',
  includes: [
    'Primero a elegir',
    'Segundo a elegir',
    'Postre casero o café',
    'Pan y bebida incluidos',
  ],
};

// Selección variada: un poco de todo, no solo recetario tradicional.
const destacados: Dish[] = [
  { tag: 'A la brasa', name: 'Entrecot de ternera', desc: 'Con guarnición a elegir', price: '15,00 €' },
  { tag: 'Del mar', name: 'Bacalao confitado', desc: 'Sobre pisto de verduras', price: '13,50 €' },
  { tag: 'Arroces', name: 'Arroz meloso del día', desc: 'Pregunta por el de hoy', price: '14,00 €' },
  { tag: 'Para compartir', name: 'Tabla de ibéricos y quesos', price: '12,00 €' },
  { tag: 'De siempre', name: 'Migas con uva y panceta', desc: 'Un clásico de la casa', price: '9,50 €' },
  { tag: 'Dulce', name: 'Postres caseros', desc: 'Tarta del día, arroz con leche…', price: '4,50 €' },
];
---

<section id="carta" class="menu-section">
  <div class="menu-inner">
    <header class="menu-head reveal">
      <p class="eyebrow">• Destacados de la carta •</p>
      <h2 class="section-title">Nuestros platos más pedidos</h2>
      <p class="section-lead">
        Una pequeña selección de los platos que más nos piden. Cocina de mercado
        para todos los gustos, con un poco de todo: carnes a la brasa, pescados,
        arroces y los caseros de siempre. Pregunta por las sugerencias del día.
      </p>
    </header>

    <div class="menu-grid">
      <!-- Menú del día destacado -->
      <article class="dia-card reveal">
        <div class="dia-tag">
          <Icon name="lucide:utensils-crossed" />
          <span>Menú del día</span>
        </div>
        <p class="dia-price">{menuDelDia.price}</p>
        <p class="dia-days">{menuDelDia.days}</p>
        <ul class="dia-list">
          {menuDelDia.includes.map((item) => (
            <li>
              <Icon name="lucide:check" class="dia-check" />
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <a href="#contacto" class="primary-btn dia-btn">
          Reservar mesa <Icon name="lucide:arrow-right" />
        </a>
      </article>

      <!-- Platos destacados -->
      <div class="dest-grid">
        {destacados.map((dish, i) => (
          <article class="dest-card reveal" style={`--reveal-delay:${i * 70}ms`}>
            <span class="dest-tag">{dish.tag}</span>
            <div class="dest-body">
              <h3 class="dest-name">{dish.name}</h3>
              {dish.desc && <p class="dest-desc">{dish.desc}</p>}
            </div>
            <span class="dest-price">{dish.price}</span>
          </article>
        ))}
      </div>
    </div>

    <!-- Enlace a la carta completa -->
    <div class="menu-cta reveal">
      <a href="/carta" class="secondary-btn">
        Ver carta completa <Icon name="lucide:arrow-right" />
      </a>
    </div>
  </div>
</section>

<style>
  .menu-section {
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-secondary) 35%, var(--color-secondary) 100%);
    padding: 5rem 1.5rem;
  }

  .menu-inner {
    max-width: 72rem;
    margin: 0 auto;
  }

  .menu-head {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .menu-grid {
    display: grid;
    gap: 1.5rem;
  }

  /* ---- Menú del día ---- */
  .dia-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 2rem;
    border-radius: 1.5rem;
    background:
      linear-gradient(160deg, rgba(201, 169, 97, 0.14), rgba(201, 169, 97, 0.02)),
      var(--color-secondary);
    border: 1px solid var(--color-accent-25);
    box-shadow: 0 20px 50px -25px rgba(0, 0, 0, 0.8);
  }

  .dia-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    align-self: flex-start;
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    background: var(--color-accent);
    color: #1a120a;
    font-family: var(--font-sans-semibold);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .dia-price {
    font-family: var(--font-serif-semibold);
    font-size: 2.75rem;
    line-height: 1;
    color: var(--color-text);
    margin: 1.25rem 0 0.25rem;
  }

  .dia-days {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .dia-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .dia-list li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .dia-check {
    color: var(--color-accent);
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
  }

  .dia-btn {
    align-self: flex-start;
  }

  /* ---- Platos destacados ---- */
  .dest-grid {
    display: grid;
    gap: 1.5rem;
  }

  .dest-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    transition:
      border-color 0.3s ease,
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .dest-card:hover {
    border-color: var(--color-accent-25);
    transform: translateY(-3px);
    box-shadow: 0 18px 40px -28px rgba(0, 0, 0, 0.9);
  }

  .dest-tag {
    align-self: flex-start;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: var(--font-sans-semibold);
    color: var(--color-accent);
    background: var(--color-accent-25);
  }

  .dest-body {
    flex: 1;
  }

  .dest-name {
    font-family: var(--font-serif-semibold);
    font-size: 1.1rem;
    color: var(--color-text);
    margin: 0;
  }

  .dest-desc {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    line-height: 1.5;
    margin: 0.35rem 0 0;
  }

  .dest-price {
    color: var(--color-accent);
    font-family: var(--font-sans-semibold);
    font-size: 1rem;
  }

  /* ---- CTA ---- */
  .menu-cta {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }

  @media (min-width: 640px) {
    .dest-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .menu-section {
      padding: 7rem 3rem;
    }
  }

  @media (min-width: 1024px) {
    .menu-grid {
      grid-template-columns: 20rem 1fr;
      align-items: start;
    }
    .dia-card {
      position: sticky;
      top: 6.5rem;
    }
  }
</style>
