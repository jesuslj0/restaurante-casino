---
import { Icon } from 'astro-icon/components';

interface Dish {
  tag: string;
  name: string;
  desc?: string;
  price: string;
}

// Selección de platos destacados extraídos de la carta real.
const destacados: Dish[] = [
  { tag: 'Ibéricos', name: 'Jamón ibérico de Huelva', desc: 'Selección de bellota', price: '16,00 €' },
  { tag: 'Del mar', name: 'Gamba blanca de Huelva', desc: 'A la plancha o cocida', price: '18,50 €' },
  { tag: 'Para picar', name: 'Tomate raf con anchoas de Santoña', price: '18,00 €' },
  { tag: 'A la plancha', name: 'Secreto ibérico', desc: 'Tapa de carne de la casa', price: '14,00 €' },
  { tag: 'De siempre', name: 'Croquetas variadas', desc: 'Gamba, boletus, jamón, bacalao y toro', price: '2,50 €/ud' },
  { tag: 'Dulce', name: 'Tiramisú casero', desc: 'Receta de la casa', price: '6,00 €' },
];

// Categorías rápidas para dar una idea del alcance de la carta.
const familias = [
  { icon: 'lucide:utensils', label: 'Para picar' },
  { icon: 'lucide:beef', label: 'Tapas de carne' },
  { icon: 'lucide:fish', label: 'Tapas de pescado' },
  { icon: 'lucide:sandwich', label: 'Bocadillería' },
  { icon: 'lucide:wine', label: 'Vinos' },
];
---

<section id="carta" class="menu-section">
  <div class="menu-inner">
    <header class="menu-head reveal">
      <p class="eyebrow">• Destacados de la carta •</p>
      <h2 class="section-title">Nuestros platos más pedidos</h2>
      <p class="section-lead">
        Cocina casera y de mercado, con un poco de todo: para picar, tapas de
        carne y pescado, ibéricos de Huelva, hamburguesas, bocadillería y postres
        caseros. Pregunta por las sugerencias del día.
      </p>
    </header>

    <!-- Familias de la carta -->
    <ul class="familia-list reveal">
      {familias.map((f) => (
        <li class="familia-chip">
          <Icon name={f.icon} />
          <span>{f.label}</span>
        </li>
      ))}
    </ul>

    <!-- Platos destacados -->
    <div class="dest-grid">
      {destacados.map((dish, i) => (
        <article class="dest-card reveal" style={`--reveal-delay:${i * 70}ms`}>
          <span class="dest-tag">{dish.tag}</span>
          <div class="dest-body">
            <h3 class="dest-name">{dish.name}</h3>
            {dish.desc && <p class="dest-desc">{dish.desc}</p>}
          </div>
          <span class="dest-price">{dish.price}</span>
        </article>
      ))}
    </div>

    <!-- Enlace a la carta completa -->
    <div class="menu-cta reveal">
      <a href="/carta" class="primary-btn">
        Ver carta completa <Icon name="lucide:arrow-right" />
      </a>
    </div>
  </div>
</section>

<style>
  .menu-section {
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-secondary) 35%, var(--color-secondary) 100%);
    padding: 5rem 1.5rem;
  }

  .menu-inner {
    max-width: 72rem;
    margin: 0 auto;
  }

  .menu-head {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  /* ---- Familias de la carta ---- */
  .familia-list {
    list-style: none;
    margin: 0 0 3rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }
  .familia-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--color-text);
    font-size: 0.85rem;
  }
  .familia-chip :global(svg) {
    width: 1.05rem;
    height: 1.05rem;
    color: var(--color-accent);
  }

  /* ---- Platos destacados ---- */
  .dest-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  .dest-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    transition:
      border-color 0.3s ease,
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .dest-card:hover {
    border-color: var(--color-accent-25);
    transform: translateY(-3px);
    box-shadow: 0 18px 40px -28px rgba(0, 0, 0, 0.9);
  }

  .dest-tag {
    align-self: flex-start;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: var(--font-sans-semibold);
    color: var(--color-accent);
    background: var(--color-accent-25);
  }

  .dest-body {
    flex: 1;
  }

  .dest-name {
    font-family: var(--font-serif-semibold);
    font-size: 1.1rem;
    color: var(--color-text);
    margin: 0;
  }

  .dest-desc {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    line-height: 1.5;
    margin: 0.35rem 0 0;
  }

  .dest-price {
    color: var(--color-accent);
    font-family: var(--font-sans-semibold);
    font-size: 1rem;
  }

  /* ---- CTA ---- */
  .menu-cta {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }

  @media (min-width: 640px) {
    .dest-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .menu-section {
      padding: 7rem 3rem;
    }
  }

  @media (min-width: 1024px) {
    .dest-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
