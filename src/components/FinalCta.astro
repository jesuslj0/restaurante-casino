---
import { Icon } from 'astro-icon/components';

interface Props {
  phone?: string;      // formato visible
  phoneIntl?: string;  // formato internacional para WhatsApp / tel:
}

// NOTA: mismos datos de ejemplo que en Contacto. Sustituir por los reales del negocio.
const { phone = '967 00 00 00', phoneIntl = '34967000000' } = Astro.props;

const waText = encodeURIComponent('¡Hola! Me gustaría reservar mesa en El Casino.');
const waHref = `https://wa.me/${phoneIntl}?text=${waText}`;
---

<section class="cta-section">
  <div class="cta-inner reveal">
    <div class="cta-bg" aria-hidden="true"></div>
    <p class="eyebrow">• Plaza Mayor, 5 · El Bonillo •</p>
    <h2 class="cta-title">Un sitio al que <span class="title-highlight">se vuelve</span></h2>

    <div class="cta-buttons">
      <a href={waHref} target="_blank" rel="noopener noreferrer" class="primary-btn cta-wa">
        Escríbenos <Icon name="simple-icons:whatsapp" />
      </a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: linear-gradient(180deg, var(--color-secondary) 0%, var(--color-bg) 35%, var(--color-bg) 100%);
    padding: 1rem 1.5rem 6rem;
  }

  .cta-inner {
    position: relative;
    max-width: 64rem;
    margin: 0 auto;
    text-align: center;
    padding: 4rem 1.75rem;
    border-radius: 2rem;
    overflow: hidden;
    background:
      radial-gradient(120% 120% at 50% 0%, rgba(201, 169, 97, 0.18), transparent 60%),
      var(--color-secondary);
    border: 1px solid var(--color-accent-25);
    box-shadow: 0 30px 70px -40px rgba(0, 0, 0, 0.95);
  }

  /* Fondo: la Plaza Mayor como pintura monocromo marrón, casi fundida con el panel */
  .cta-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/plaza-mayor-wide.png');
    background-size: cover;
    background-position: center 65%;
    filter: sepia(1) brightness(0.45) contrast(0.9) saturate(0.7);
    opacity: 0.80;
    mix-blend-mode: luminosity;
    pointer-events: none;
    z-index: 0;
  }

  /* Velo para fundir aún más la imagen con el color del panel */
  .cta-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(120% 150% at 50% 0%, transparent 0%, var(--color-secondary) 85%),
      linear-gradient(180deg, transparent 60%, color-mix(in srgb, var(--color-secondary) 70%, transparent) 100%);
  }

  .cta-inner > :not(.cta-bg) {
    position: relative;
    z-index: 1;
  }

  .cta-title {
    font-family: var(--font-serif-semibold);
    color: var(--color-text);
    font-size: clamp(2rem, 1.4rem + 3vw, 3.25rem);
    line-height: 1.1;
    margin: 0.75rem 0 0;
  }

  .cta-lead {
    color: var(--color-text-secondary);
    font-size: clamp(1rem, 0.95rem + 0.3vw, 1.15rem);
    line-height: 1.7;
    max-width: 38rem;
    margin: 1.25rem auto 0;
  }

  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
    margin-top: 2.25rem;
  }

  @media (min-width: 768px) {
    .cta-section {
      padding: 2rem 3rem 8rem;
    }
    .cta-inner {
      padding: 5rem 3rem;
    }
  }
</style>
