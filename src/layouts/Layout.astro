---
import '../styles/global.css';
import '../styles/buttons.css';

const { title, description } = Astro.props;

// Datos estructurados para SEO local (schema.org Restaurant).
// Solo datos verificables: dirección y horarios reales del local.
const restaurantSchema = {
	'@context': 'https://schema.org',
	'@type': 'Restaurant',
	name: 'El Casino',
	description:
		'Bar y restaurante en la Plaza Mayor de El Bonillo. Cocina casera y de mercado: almuerzos, menú del día y cenas de fin de semana.',
	servesCuisine: ['Española', 'Mediterránea', 'Casera'],
	priceRange: '€€',
	address: {
		'@type': 'PostalAddress',
		streetAddress: 'Plaza Mayor, 5',
		addressLocality: 'El Bonillo',
		addressRegion: 'Albacete',
		postalCode: '02610',
		addressCountry: 'ES',
	},
	openingHoursSpecification: [
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: ['Tuesday', 'Wednesday', 'Thursday', 'Friday'],
			opens: '09:00',
			closes: '20:00',
		},
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: ['Saturday', 'Sunday'],
			opens: '09:00',
			closes: '23:59',
		},
	],
};
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description ?? 'El Casino de El Bonillo — bar y restaurante en la Plaza Mayor. Almuerzos, menú del día y cenas de fin de semana con cocina casera para todos los gustos.'} />
		<meta name="theme-color" content="#0a0a0a" />
		<title>{title}</title>
		<script type="application/ld+json" set:html={JSON.stringify(restaurantSchema)} is:inline />
	</head>
	<body class="min-h-screen flex flex-col w-full">
		<slot name="header" />
		<main class="flex-1">
			<slot />
		</main>
		<slot name="footer" />

		<script>
			const els = document.querySelectorAll<HTMLElement>('.reveal');
			const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			if (reduce || !('IntersectionObserver' in window)) {
				els.forEach((el) => el.classList.add('is-visible'));
			} else {
				const io = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-visible');
								io.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
				);
				els.forEach((el) => io.observe(el));
			}
		</script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
