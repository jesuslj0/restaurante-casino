---
import '../styles/global.css';
import '../styles/buttons.css';

const { title, description } = Astro.props;

// En la carta hay una píldora de categorías arriba (en ambos tamaños),
// así que el desvanecido superior debe activarse también en móvil.
const onCarta = Astro.url.pathname.startsWith('/carta');

// Datos estructurados para SEO local (schema.org Restaurant).
// Solo datos verificables: dirección y horarios reales del local.
const restaurantSchema = {
	'@context': 'https://schema.org',
	'@type': 'Restaurant',
	name: 'El Casino',
	description:
		'Bar y restaurante en la Plaza Mayor de El Bonillo. Cocina casera y de mercado: almuerzos, menú del día y cenas de fin de semana.',
	servesCuisine: ['Española', 'Mediterránea', 'Casera'],
	priceRange: '€€',
	address: {
		'@type': 'PostalAddress',
		streetAddress: 'Plaza Mayor, 5',
		addressLocality: 'El Bonillo',
		addressRegion: 'Albacete',
		postalCode: '02610',
		addressCountry: 'ES',
	},
	openingHoursSpecification: [
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: ['Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
			opens: '08:30',
			closes: '01:00',
		},
	],
};
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description ?? 'El Casino de El Bonillo — bar y restaurante en la Plaza Mayor. Almuerzos, menú del día y cenas de fin de semana con cocina casera para todos los gustos.'} />
		<meta name="theme-color" content="#0a0a0a" />
		<title>{title}</title>
		<script type="application/ld+json" set:html={JSON.stringify(restaurantSchema)} is:inline />
	</head>
	<body class:list={['min-h-screen flex flex-col w-full', { 'is-carta': onCarta }]}>
		<!-- Desvanecidos: funden el contenido con el fondo antes de pasar tras los navbar -->
		<div class="scrim scrim-top" aria-hidden="true"></div>
		<div class="scrim scrim-bottom" aria-hidden="true"></div>

		<slot name="header" />
		<main class="flex-1">
			<slot />
		</main>
		<slot name="footer" />

		<script>
			const els = document.querySelectorAll<HTMLElement>('.reveal');
			const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			if (reduce || !('IntersectionObserver' in window)) {
				els.forEach((el) => el.classList.add('is-visible'));
			} else {
				const io = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-visible');
								io.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
				);
				els.forEach((el) => io.observe(el));
			}
		</script>
	</body>
</html>

<style>
	html {
		min-height: 100%;
	}
	html,
	body {
		margin: 0;
		width: 100%;
	}

	/* ---------- Desvanecidos junto a los navbar flotantes ---------- */
	/* z entre el contenido (0) y las píldoras (cat-nav 30, navbar 50):
	   las barras quedan nítidas y el contenido se funde con el fondo. */
	.scrim {
		position: fixed;
		left: 0;
		right: 0;
		z-index: 20;
		pointer-events: none;
	}

	.scrim-top {
		top: 0;
		height: 4.5rem;
		background: linear-gradient(to bottom, var(--color-bg) 35%, transparent);
		/* En móvil solo se activa en la carta (píldora de categorías arriba) */
		display: none;
	}

	.scrim-bottom {
		bottom: 0;
		height: 6rem;
		background: linear-gradient(to top, var(--color-bg) 35%, transparent);
		display: block;
	}

	/* Carta: la píldora de categorías vive arriba también en móvil */
	body.is-carta .scrim-top {
		display: block;
	}

	/* Escritorio: el navbar principal pasa arriba; el de abajo desaparece */
	@media (min-width: 640px) {
		.scrim-top {
			display: block;
			height: 6rem;
		}
		.scrim-bottom {
			display: none;
		}
		/* En la carta hay navbar + píldora de categorías: más recorrido de fundido */
		body.is-carta .scrim-top {
			height: 8.5rem;
		}
	}
</style>
