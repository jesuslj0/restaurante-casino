---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Specialities from '../components/Specialities.astro';
import About from '../components/About.astro';
import Hours from '../components/Hours.astro';
import Gallery from '../components/Gallery.astro';
import Reviews from '../components/Reviews.astro';
import Location from '../components/Location.astro';
import Contact from '../components/Contact.astro';
import FinalCta from '../components/FinalCta.astro';
import ReviewPrompt from '../components/ReviewPrompt.astro';

const props = {
	restaurantName: 'El Casino',
	location: 'Plaza Mayor, Nº5 - El Bonillo (AB)',
};

const heroProps = {
	heroTitle: 'Tu sitio en la Plaza Mayor',
	heroSubtitle: 'Cocina casera y de mercado en un ambiente familiar para disfrutar con quien quieras.',
	buttonText: 'Reservar mesa',
	buttonSecondaryText: 'Ver carta',
	location: 'Plaza Mayor, Nº5 - El Bonillo',
	schedule: 'Mar a Dom: 8:30 - 1:00',
};

const socialProps = {
	facebookUsername: 'elcasino',
	instagramUsername: 'casinoelbonillo',
	xUsername: 'el_casino',
};
---

<Layout title="El Casino · Bar y restaurante en la Plaza Mayor de El Bonillo">
	<Header slot="header" />

	<Hero
		title={heroProps.heroTitle}
		subtitle={heroProps.heroSubtitle}
		restaurantName={props.restaurantName}
		buttonText={heroProps.buttonText}
		buttonSecondaryText={heroProps.buttonSecondaryText}
		location={heroProps.location}
		schedule={heroProps.schedule}
	/>

	<Specialities />

	<Gallery />

	<About
		restaurantName={props.restaurantName}
		description="Un rincón de toda la vida con un toque actual, en el corazón de El Bonillo. Cocina casera y variada, hecha al momento y con buen producto."
	/>

	<Reviews />

	<Hours />

	<Location />

	<Contact />

	<FinalCta />

	<ReviewPrompt />

	<Footer
		slot="footer"
		restaurantName={props.restaurantName}
		location={props.location}
		facebookUsername={socialProps.facebookUsername}
		instagramUsername={socialProps.instagramUsername}
		xUsername={socialProps.xUsername}
	/>
</Layout>
